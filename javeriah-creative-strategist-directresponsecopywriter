<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neurobella — Creative Strategist Onboarding (Hypertensive Retinopathy)</title>
<style>
  :root{
    --bg:#0d1411; --bg-2:#101b16; --card:#14211b; --card-2:#18271f;
    --line:#23362c; --ink:#eef5ef; --muted:#9bb3a4; --muted-2:#7d978a;
    --green:#1fd07a; --green-deep:#0fa860; --lime:#b8f04a; --gold:#f5c451;
    --orange:#ff8a4c; --red:#ff6b6b; --blue:#5cc8ff; --violet:#b58cff; --radius:18px; --maxw:1080px;
    font-synthesis:none;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(31,208,122,.10), transparent 60%),
      radial-gradient(900px 500px at -10% 10%, rgba(184,240,74,.06), transparent 55%),
      var(--bg);
    color:var(--ink);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    line-height:1.55;-webkit-font-smoothing:antialiased;overflow-x:hidden;
  }
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}
  nav{position:sticky;top:0;z-index:50;backdrop-filter:blur(12px);background:rgba(13,20,17,.82);border-bottom:1px solid var(--line)}
  .nav-inner{max-width:var(--maxw);margin:0 auto;padding:12px 22px;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
  .brand{display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.5px;font-size:16px}
  .logo{width:30px;height:30px;border-radius:9px;background:linear-gradient(135deg,var(--green),var(--lime));display:grid;place-items:center;color:#06160f;font-weight:900;font-size:16px}
  .nav-links{display:flex;gap:2px;margin-left:auto;flex-wrap:wrap}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:12.5px;font-weight:600;padding:7px 10px;border-radius:9px;transition:.2s}
  .nav-links a:hover{color:var(--ink);background:var(--card-2)}
  header{padding:74px 0 40px;position:relative}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--green);background:rgba(31,208,122,.10);border:1px solid rgba(31,208,122,.25);padding:7px 14px;border-radius:100px}
  h1{font-size:clamp(34px,6vw,60px);line-height:1.04;letter-spacing:-1.5px;margin:22px 0 16px;font-weight:850}
  h1 .hl{background:linear-gradient(120deg,var(--green),var(--lime));-webkit-background-clip:text;background-clip:text;color:transparent}
  .sub{font-size:clamp(16px,2.4vw,20px);color:var(--muted);max-width:680px}
  .hero-kpi{display:flex;gap:14px;flex-wrap:wrap;margin-top:34px}
  .kpi{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:16px;padding:18px 22px;min-width:140px}
  .kpi .n{font-size:30px;font-weight:850;background:linear-gradient(120deg,var(--green),var(--lime));-webkit-background-clip:text;background-clip:text;color:transparent}
  .kpi .l{font-size:12.5px;color:var(--muted);margin-top:3px;font-weight:600;letter-spacing:.3px}
  section{padding:46px 0;border-top:1px solid var(--line)}
  .sec-tag{font-size:12px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--green)}
  h2{font-size:clamp(24px,4vw,34px);letter-spacing:-.8px;margin:10px 0 8px;font-weight:820}
  .lead{color:var(--muted);max-width:740px;font-size:16px}
  .grid{display:grid;gap:16px;margin-top:26px}
  .g2{grid-template-columns:repeat(2,1fr)}
  .g3{grid-template-columns:repeat(3,1fr)}
  .g4{grid-template-columns:repeat(4,1fr)}
  @media(max-width:820px){.g2,.g3,.g4{grid-template-columns:1fr}}
  .card{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:var(--radius);padding:22px;transition:.25s;position:relative}
  .card:hover{border-color:rgba(31,208,122,.4);transform:translateY(-3px)}
  .card h3{font-size:17px;margin-bottom:7px;font-weight:750;display:flex;align-items:center;gap:9px}
  .card p{color:var(--muted);font-size:14.5px}
  .chip{display:inline-grid;place-items:center;width:34px;height:34px;border-radius:10px;font-size:18px;background:var(--card-2);border:1px solid var(--line);flex:none}
  .banner{background:linear-gradient(135deg,rgba(31,208,122,.14),rgba(184,240,74,.06));border:1px solid rgba(31,208,122,.3);border-radius:20px;padding:30px 28px;display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap}
  .banner.amber{background:linear-gradient(135deg,rgba(245,196,81,.14),rgba(255,138,76,.06));border-color:rgba(245,196,81,.32)}
  .banner.violet{background:linear-gradient(135deg,rgba(181,140,255,.14),rgba(92,200,255,.06));border-color:rgba(181,140,255,.32)}
  .banner .big{font-size:46px;line-height:1}
  .banner h3{font-size:20px;margin-bottom:6px}
  .banner p{color:var(--muted);font-size:15px;max-width:820px}
  .levels{display:grid;gap:12px;margin-top:24px}
  .level{display:grid;grid-template-columns:64px 1fr;gap:18px;align-items:center;background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-left:4px solid var(--lv);border-radius:16px;padding:18px 22px;transition:.2s}
  .level:hover{transform:translateX(4px)}
  .level.locked{opacity:.6}
  .lv-badge{width:64px;height:64px;border-radius:14px;display:grid;place-items:center;font-weight:900;font-size:24px;color:#06160f;background:linear-gradient(150deg,var(--lv),var(--lv2))}
  .level h3{font-size:17px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:4px}
  .level p{color:var(--muted);font-size:14px}
  .tag-mini{font-size:10.5px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;padding:3px 9px;border-radius:100px;background:var(--card-2);border:1px solid var(--line);color:var(--muted)}
  .tag-go{background:rgba(31,208,122,.14);border-color:rgba(31,208,122,.3);color:var(--green)}
  .tag-lock{background:rgba(255,107,107,.12);border-color:rgba(255,107,107,.3);color:var(--red)}
  .flow{position:relative;margin-top:30px;padding-left:8px}
  .step{display:grid;grid-template-columns:48px 1fr;gap:20px;position:relative;padding-bottom:26px}
  .step:not(:last-child)::before{content:"";position:absolute;left:23px;top:48px;bottom:-4px;width:2px;background:linear-gradient(var(--line),transparent)}
  .step-num{width:48px;height:48px;border-radius:13px;background:linear-gradient(150deg,var(--green),var(--green-deep));color:#06160f;display:grid;place-items:center;font-weight:900;font-size:18px;flex:none;z-index:1;box-shadow:0 6px 18px rgba(31,208,122,.25)}
  .step-body{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:16px;padding:18px 22px}
  .step-body h3{font-size:17px;margin-bottom:6px;font-weight:750}
  .step-body p{color:var(--muted);font-size:14.5px}
  .step-body ul{margin:10px 0 0;padding-left:18px;color:var(--muted);font-size:14px}
  .step-body li{margin:4px 0}
  .pill{display:inline-block;font-size:11px;font-weight:700;color:var(--green);background:rgba(31,208,122,.1);border:1px solid rgba(31,208,122,.25);padding:3px 10px;border-radius:100px;margin-top:10px}
  .gate .step-num{background:linear-gradient(150deg,var(--gold),var(--orange));box-shadow:0 6px 18px rgba(245,196,81,.25)}
  .code-box{font-family:ui-monospace,Menlo,Consolas,monospace;font-size:13px;background:#0a120e;border:1px solid var(--line);border-radius:10px;padding:12px 14px;margin-top:12px;color:var(--lime);overflow-x:auto;white-space:nowrap}
  .loop{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:24px}
  @media(max-width:820px){.loop{grid-template-columns:1fr 1fr}}
  .loop-step{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:16px;padding:20px;text-align:center;position:relative}
  .loop-step .ic{font-size:30px}.loop-step h4{font-size:15px;margin:8px 0 5px}.loop-step p{font-size:13px;color:var(--muted)}
  .loop-step::after{content:"→";position:absolute;right:-12px;top:50%;transform:translateY(-50%);color:var(--green);font-weight:900;font-size:18px}
  .loop-step:last-child::after{content:"↺"}
  @media(max-width:820px){.loop-step::after{display:none}}
  .codes{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:22px}
  @media(max-width:820px){.codes{grid-template-columns:1fr}}
  .codecard{display:flex;gap:12px;align-items:flex-start;background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:13px;padding:14px 16px}
  .codecard .k{font-family:ui-monospace,monospace;font-weight:800;font-size:12.5px;color:var(--gold);background:rgba(245,196,81,.1);border:1px solid rgba(245,196,81,.25);padding:3px 8px;border-radius:7px;flex:none;min-width:62px;text-align:center}
  .codecard p{font-size:13.5px;color:var(--muted)}.codecard b{color:var(--ink);font-weight:650}
  .fmtgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:18px}
  @media(max-width:820px){.fmtgrid{grid-template-columns:1fr 1fr}}
  @media(max-width:520px){.fmtgrid{grid-template-columns:1fr}}
  .fmt{display:flex;gap:9px;align-items:baseline;background:var(--card);border:1px solid var(--line);border-radius:10px;padding:9px 11px;font-size:12.5px}
  .fmt .c{font-family:ui-monospace,monospace;color:var(--lime);font-weight:700;flex:none}
  .fmt .d{color:var(--muted)}
  .angle-card{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:16px;padding:20px 22px;border-left:4px solid var(--ac)}
  .angle-card h3{font-size:18px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .angle-card .spend{font-size:13px;color:var(--muted);margin-top:6px}
  .status{font-size:10.5px;font-weight:800;letter-spacing:.6px;text-transform:uppercase;padding:4px 10px;border-radius:100px}
  .st-main{background:rgba(31,208,122,.16);color:var(--green);border:1px solid rgba(31,208,122,.35)}
  .st-scale{background:rgba(92,200,255,.14);color:var(--blue);border:1px solid rgba(92,200,255,.32)}
  .st-new{background:rgba(245,196,81,.14);color:var(--gold);border:1px solid rgba(245,196,81,.3)}
  .test-list{margin-top:18px;display:grid;gap:10px}
  .test-row{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:13px;padding:14px 18px}
  .test-row .cond{font-weight:700;font-size:15px}
  .test-row .sym{color:var(--muted);font-size:14px;margin-top:3px}
  .test-row .sym em{color:var(--muted-2);font-style:italic}
  .group-label{font-size:12px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold);margin:18px 0 4px}
  .tool{display:flex;align-items:center;gap:14px;background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:14px;padding:15px 18px}
  .tool .ic{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;font-size:20px;background:var(--card-2);border:1px solid var(--line);flex:none}
  .tool h4{font-size:15px;margin-bottom:2px}.tool p{font-size:13px;color:var(--muted)}
  .rhythm .card h3{font-size:16px}.time-tag{font-size:11px;font-weight:800;color:var(--gold);letter-spacing:.5px}
  .angle-divider{margin-top:30px;padding:22px 24px;border-radius:18px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;border:1px solid var(--ad-line);background:linear-gradient(135deg,var(--ad-bg),transparent);scroll-margin-top:80px}
  .angle-divider .ad-ic{font-size:34px;line-height:1}
  .angle-divider .ad-name{font-size:22px;font-weight:820;letter-spacing:-.4px}
  .angle-divider .ad-out{color:var(--muted);font-size:14px;margin-top:3px}
  .check-wrap{background:linear-gradient(160deg,var(--card),var(--bg-2));border:1px solid var(--line);border-radius:20px;padding:26px;margin-top:24px}
  .progress{height:10px;border-radius:100px;background:var(--card-2);overflow:hidden;margin:6px 0 22px;border:1px solid var(--line)}
  .progress-bar{height:100%;width:0;background:linear-gradient(90deg,var(--green),var(--lime));border-radius:100px;transition:width .4s ease}
  .check-item{display:flex;align-items:flex-start;gap:13px;padding:13px 0;border-bottom:1px solid var(--line);cursor:pointer;user-select:none}
  .check-item:last-child{border-bottom:none}
  .box{width:24px;height:24px;border-radius:7px;border:2px solid var(--muted-2);flex:none;display:grid;place-items:center;transition:.2s;margin-top:1px}
  .check-item.done .box{background:linear-gradient(135deg,var(--green),var(--lime));border-color:transparent}
  .box svg{opacity:0;transition:.2s}.check-item.done .box svg{opacity:1}
  .check-item .txt{font-size:15px}.check-item.done .txt{color:var(--muted-2);text-decoration:line-through}
  .check-item .txt small{display:block;color:var(--muted);font-size:13px;text-decoration:none;margin-top:2px}
  .check-item.done .txt small{color:var(--muted-2)}
  footer{padding:50px 0 70px;text-align:center;color:var(--muted-2);font-size:13px;border-top:1px solid var(--line)}
  footer .logo{margin:0 auto 14px}
  .reveal{opacity:0;transform:translateY(24px);transition:.6s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}
</style>
</head>
