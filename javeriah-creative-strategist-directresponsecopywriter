    <p><strong>Neurobella</strong> — Creative Strategy Onboarding</p>
    <p style="margin-top:6px">Study the winners. Start at Level 2. Test, learn, scale. 🚀</p>
  </div>
</footer>

<script>
  const items = [
    ["Get access to all tools","Master Sheet, Notion, Time Doctor, AdSpy/Kalodata, Adnova, Meta, Slack, Loom"],
    ["Watch the Loom walkthroughs","Learn the Master Sheet, Notion board & the SOPs"],
    ["Study the Legend tab","Concept levels, creative formats & iteration codes"],
    ["Study every winning ad","Read the full breakdowns in the Master Sheet"],
    ["Internalize the levels","Start at Level 2 → 3, 4, 5 from learnings (skip Level 1)"],
    ["Learn the locked brief","Cuff Trap mechanism + all 3 avatars + the through-line"],
    ["Pick your first avatar","Avatar 1, 2 or 3 — confirm the moving parts you'll work with"],
    ["Do deep research","Amazon + Reddit + Facebook groups + Claude"],
    ["Send research for approval","⛔ Wait for sign-off before briefing"],
    ["Set up Time Doctor & first Slack reports","Build the clock-in + BOD/EOD habit"],
    ["Write & log your first Level 2 briefs","18 native + 7 videos — tag avatar, format & level"],
    ["Create Notion cards with naming convention","Batch · Concept · Angle · Avatar · Awareness · Format · Goal"],
    ["Know where to pull your data","Media buyer · Adnova creative analytics · Ads Manager"]
  ];
  const list = document.getElementById('checklist');
  let done = new Set();
  function render(){
    list.innerHTML='';
    items.forEach((it,i)=>{
      const row=document.createElement('div');
      row.className='check-item'+(done.has(i)?' done':'');
      row.innerHTML=`<div class="box"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#06160f" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="txt">${it[0]}<small>${it[1]}</small></div>`;
      row.onclick=()=>{done.has(i)?done.delete(i):done.add(i);render();};
      list.appendChild(row);
    });
    const pct=Math.round(done.size/items.length*100);
    document.getElementById('bar').style.width=pct+'%';
    document.getElementById('pct').textContent=pct+'%';
  }
  render();
  const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:0,rootMargin:"0px 0px -60px 0px"});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
